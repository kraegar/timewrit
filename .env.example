# —————————————————————————————————————————————————————————————————————
# LOCAL DEVELOPMENT SETTINGS
# —————————————————————————————————————————————————————————————————————
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# —————————————————————————————————————————————————————————————————————
# CLOUD / ENTERPRISE DEPLOYMENT SETTINGS
# —————————————————————————————————————————————————————————————————————

# 1. Database (PostgreSQL / Cloud SQL)
# For CloudSQL, use: DATABASE_URL=postgres://user:password@/dbname?host=/cloudsql/project:region:instance
# DATABASE_URL=

# 2. Authentication
USE_IAP=False
IAP_USER_HEADER=HTTP_X_GOOG_AUTHENTICATED_USER_EMAIL

USE_GOOGLE_OAUTH=False
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 3. Storage (Google Cloud Storage)
USE_GCS=False
GS_BUCKET_NAME=your-gcs-bucket-name
GS_PROJECT_ID=your-gcp-project-id

# 4. Caching (Redis / Memorystore)
USE_REDIS=False
REDIS_URL=redis://localhost:6379/0

# 5. Logging & Monitoring (Cloud Monitoring)
USE_CLOUD_LOGGING=False

# 6. Email (Console vs. SendGrid/SMTP)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# 7. Other Cloud Settings
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
